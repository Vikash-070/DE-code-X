{
  "name": "decode-x-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "dotenv -e .env -- next dev apps/web",
    "build": "dotenv -e .env -- next build apps/web",
    "start": "dotenv -e .env -- next start apps/web",
    "lint": "dotenv -e .env -- next lint apps/web",
    "build:prod": "prisma generate --schema packages/config/prisma/schema.prisma && next build apps/web",
    "start:prod": "next start apps/web -p ${PORT:-3000}",
    "postinstall": "prisma generate --schema packages/config/prisma/schema.prisma",
    "prisma:generate": "dotenv -e .env -- prisma generate --schema packages/config/prisma/schema.prisma",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev --schema packages/config/prisma/schema.prisma",
    "prisma:studio": "dotenv -e .env -- prisma studio --schema packages/config/prisma/schema.prisma",
    "prisma:push": "dotenv -e .env -- prisma db push --schema packages/config/prisma/schema.prisma",
    "env:check": "dotenv -e .env -- node -e \"['DATABASE_URL','ENCRYPTION_KEY','CLERK_SECRET_KEY','NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY'].forEach(k=>{if(!process.env[k])throw new Error('Missing env var: '+k);console.log('\\u2713',k)})\" "
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@clerk/nextjs": "^7.4.1",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.468.0",
    "next": "^15.5.18",
    "openai": "^6.39.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.19.0",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.10",
    "prisma": "^6.19.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
