# ─────────────────────────────────────────────────────────
# DE-code X — environment variable documentation
#
# Copy this file to .env at the repo root and fill in real values.
#
#   cp .env.example .env
#
# The .env file is the single runtime source of truth for all services:
#   • Next.js dev/build/start (loaded via dotenv-cli)
#   • Prisma CLI (auto-detected from cwd)
#   • Server-side AI orchestration routes
#
# NEVER commit .env or any file containing real secrets.
# ─────────────────────────────────────────────────────────


# ── Clerk Authentication ──────────────────────────────────
# Obtain from: https://dashboard.clerk.com → your app → API Keys

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Clerk routing — where sign-in/sign-up pages live
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/workspace
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/workspace


# ── Database (Supabase PostgreSQL) ───────────────────────
# Obtain from: https://supabase.com → your project → Settings → Database → Connection string
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

DATABASE_URL="postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres"


# ── Encryption ───────────────────────────────────────────
# 32-byte (64 hex char) AES-256-GCM key for encrypting BYOK provider keys at rest.
# Required — server throws on startup if missing or malformed.
#
# Generate a fresh key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

ENCRYPTION_KEY=


# ── AI Providers (optional — BYOK) ───────────────────────
# Server-side fallback keys for development/testing only.
# In production, users supply their own keys via Settings → AI Providers.
# These values are NEVER exposed to the browser.

# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-proj-...
